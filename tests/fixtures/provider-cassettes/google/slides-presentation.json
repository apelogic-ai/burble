                  }
                },
                {
                  "objectId": "layout-subtitle",
                  "shape": {
                    "shapeType": "TEXT_BOX",
                    "placeholder": {
                      "type": "SUBTITLE",
                      "index": 0
                    }
                  }
                }
              ]
            },
            {
