AGENT_RUNTIME_DOCKER_NETWORK={{ agent_runtime_docker_network | default('compose_default') }}
AGENT_RUNTIME_IDLE_TTL_MS={{ agent_runtime_idle_ttl_ms | default('1800000') }}
AGENT_RUNTIME_REAPER_INTERVAL_MS={{ agent_runtime_reaper_interval_ms | default('60000') }}
AGENT_RUNTIME_TOKEN_SECRET={{ agent_runtime_token_secret | default('') }}
