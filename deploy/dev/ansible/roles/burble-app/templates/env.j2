{# Rendered by ansible. Do not edit on the host; changes will be overwritten. #}
DOMAIN={{ domain }}
SLACK_BOT_TOKEN={{ slack_bot_token }}
SLACK_APP_TOKEN={{ slack_app_token }}
SLACK_LOG_LEVEL={{ slack_log_level | default('info') }}
AGENT_MODE={{ agent_mode | default('deterministic') }}
AGENT_RUNTIME={{ agent_runtime | default('ai-sdk') }}
AI_MODEL={{ ai_model | default('openai:gpt-5.4') }}
OPENCLAW_NEMOCLAW_URL={{ openclaw_nemoclaw_url | default('') }}
INTERNAL_API_TOKEN={{ internal_api_token | default('') }}
OPENCLAW_NEMOCLAW_IMAGE={{ openclaw_nemoclaw_image | default('') }}
OPENCLAW_NEMOCLAW_ENGINE={{ openclaw_nemoclaw_engine | default('deterministic') }}
OPENCLAW_COMMAND={{ openclaw_command | default('openclaw') }}
OPENCLAW_AGENT={{ openclaw_agent | default('main') }}
OPENCLAW_TIMEOUT_MS={{ openclaw_timeout_ms | default('60000') }}
OPENCLAW_STATE_DIR={{ openclaw_state_dir | default('/data/openclaw/state') }}
OPENCLAW_CONFIG_PATH={{ openclaw_config_path | default('/data/openclaw/config/openclaw.json') }}
OPENCLAW_WORKSPACE_DIR={{ openclaw_workspace_dir | default('/data/openclaw/workspace') }}
OPENCLAW_SETUP_ON_START={{ openclaw_setup_on_start | default('true') }}
OPENCLAW_CONFIG_PATCH_PATH={{ openclaw_config_patch_path | default('') }}
OPENCLAW_VALIDATE_ON_START={{ openclaw_validate_on_start | default('true') }}
OPENCLAW_VERSION={{ openclaw_version | default('2026.5.19') }}
OPENAI_API_KEY={{ openai_api_key | default('') }}
ANTHROPIC_API_KEY={{ anthropic_api_key | default('') }}
GITHUB_CLIENT_ID={{ github_client_id }}
GITHUB_CLIENT_SECRET={{ github_client_secret }}
