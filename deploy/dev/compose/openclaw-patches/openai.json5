{
  agents: {
    defaults: {
      model: {
        primary: "openai/gpt-5.4"
      },
      models: {
        "openai/gpt-5.4": {
          alias: "GPT"
        }
      }
    }
  },
  logging: {
    level: "info",
    consoleLevel: "info",
    consoleStyle: "compact",
    file: "/data/openclaw/logs/openclaw.log",
    redactSensitive: "tools"
  },
  plugins: {
    entries: {
      openai: {
        enabled: true
      }
    }
  },
  auth: {
    profiles: {
      "openai:default": {
        provider: "openai",
        mode: "api_key"
      }
    },
    order: {
      openai: ["openai:default"]
    }
  }
}
