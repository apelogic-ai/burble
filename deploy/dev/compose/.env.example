# Copy to .env on the deployment host. Real .env is gitignored.

# Terraform outputs this as `nip_io_domain`, for example:
# 203.0.113.10.nip.io
DOMAIN=CHANGEME.nip.io

SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_LOG_LEVEL=info
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
AGENT_MODE=deterministic
AGENT_FAST_TRACK=false
AGENT_RUNTIME=ai-sdk
AGENT_RUNTIME_FACTORY=static
AGENT_RUNTIME_ENGINE=
AGENT_RUNTIME_IMAGE=
AGENT_RUNTIME_TOKEN_SECRET=
AGENT_RUNTIME_MCP_GATEWAY_URL=
AGENT_RUNTIME_MCP_AUDIENCE=
AGENT_RUNTIME_STREAMING=native
# Required only for AGENT_RUNTIME_FACTORY=sandbox / OpenShell-compatible
# providers. Leave AGENT_RUNTIME_SANDBOX_START_COMMAND blank for default
# Burble runtime images; the app derives it from AGENT_RUNTIME_ENGINE. Override
# it only for custom runtime images. The value accepts either JSON argv or
# shell-style words.
AGENT_RUNTIME_SANDBOX_URL=
AGENT_RUNTIME_SANDBOX_TOKEN=
AGENT_RUNTIME_SANDBOX_TRANSPORT=grpc
AGENT_RUNTIME_SANDBOX_START_COMMAND=
AGENT_RUNTIME_OPENSHELL_DIAL_HOST=
# Optional when starting the compose-managed NVIDIA OpenShell gateway with
# ./deploy-personal-runtimes.sh --openshell. Leave AGENT_RUNTIME_SANDBOX_URL
# empty in that mode; docker-compose.openshell.yml points Burble at the gateway.
OPENSHELL_IMAGE_TAG=latest
OPENSHELL_BIND_HOST=0.0.0.0
OPENSHELL_PORT=8080
OPENSHELL_HEALTH_PORT=8081
# Keep this as an absolute host path that is also mounted at the same path in
# the OpenShell gateway container. The Docker driver bind-mounts supervisor
# binaries into sandbox containers through the host Docker daemon.
OPENSHELL_DATA_ROOT=/var/lib/openshell
AI_MODEL=openai:gpt-5.4
LLM_GW_BASE_URL=http://host.openshell.internal:4000/v1
BURBLE_INFERENCE_BASE_URL=http://llm-gw:4000/v1
TASK_WORKFLOW_SHADOW_ENABLED=false
TASK_WORKFLOW_SHADOW_DATABASE_PATH=
TASK_WORKFLOW_AUTHORITY=off
TASK_WORKFLOW_MAX_ATTEMPTS=2
SCHEDULED_RUN_AUDIT_RETENTION_DAYS=90
SCHEDULED_RUN_AUDIT_PRUNE_INTERVAL_MS=86400000
OPENCLAW_NEMOCLAW_URL=
INTERNAL_API_TOKEN=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_API_KEY=
OLLAMA_BASE_URL=https://ollama.com

# Optional when using docker-compose.openclaw-nemoclaw.yml. Compose builds a
# local burble-openclaw-nemoclaw:dev image if this is empty.
OPENCLAW_NEMOCLAW_IMAGE=
OPENCLAW_NEMOCLAW_ENGINE=deterministic
OPENCLAW_COMMAND=openclaw
OPENCLAW_AGENT=main
OPENCLAW_TIMEOUT_MS=60000
OPENCLAW_STATE_DIR=/data/openclaw/state
OPENCLAW_CONFIG_PATH=/data/openclaw/config/openclaw.json
OPENCLAW_WORKSPACE_DIR=/data/openclaw/workspace
OPENCLAW_SETUP_ON_START=true
# Set to /etc/openclaw/patches/openai.json5 for the OpenClaw CLI engine.
OPENCLAW_CONFIG_PATCH_PATH=
OPENCLAW_VALIDATE_ON_START=true
OPENCLAW_STREAM_DEBUG=false
OPENCLAW_LOG_LEVEL=
OPENCLAW_DIAGNOSTICS=
OPENCLAW_DEBUG_MODEL_TRANSPORT=
OPENCLAW_DEBUG_MODEL_PAYLOAD=
OPENCLAW_DEBUG_SSE=
OPENCLAW_DEBUG_CODE_MODE=
OPENCLAW_FAST_MODE=false
OPENCLAW_VERSION=2026.5.19

GITHUB_CLIENT_ID=...
GITHUB_CLIENT_SECRET=...
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
