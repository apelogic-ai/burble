FROM node:22.19-bookworm-slim
WORKDIR /runtime
ENV NODE_ENV=production

ARG OPENCLAW_VERSION=2026.5.19
RUN apt-get update \
  && apt-get install -y --no-install-recommends git openssh-client ca-certificates \
  && rm -rf /var/lib/apt/lists/* \
  && npm install -g bun \
  && npm install -g "openclaw@${OPENCLAW_VERSION}" \
  && command -v bun \
  && command -v openclaw

COPY runtimes/openclaw-nemoclaw/package.json runtimes/openclaw-nemoclaw/tsconfig.json ./
COPY runtimes/openclaw-nemoclaw/src ./src
COPY runtimes/openclaw-nemoclaw/skills ./skills
COPY runtimes/openclaw-nemoclaw/openclaw-plugins ./openclaw-plugins
COPY src/runtime-sdk/server.ts /src/runtime-sdk/server.ts
RUN mkdir -p /runtime/openclaw-plugins/burble-channel/node_modules \
  && ln -s /usr/local/lib/node_modules/openclaw /runtime/openclaw-plugins/burble-channel/node_modules/openclaw
EXPOSE 8080
CMD ["bun", "src/index.ts"]
