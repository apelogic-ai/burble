{
  "$id": "https://burble.local/schemas/runtime-contract.schema.json",
  "version": 1,
  "schemas": {
    "RuntimeRunRequest": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "type": "object",
      "properties": {
        "runId": {
          "type": "string",
          "minLength": 1
        },
        "executionMode": {
          "type": "string",
          "enum": [
            "default",
            "native-runtime",
            "openclaw-native"
          ]
        },
        "principal": {
          "type": "object",
          "properties": {
            "workspaceId": {
              "type": "string",
              "minLength": 1
            },
            "slackUserId": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "workspaceId",
            "slackUserId"
          ],
          "additionalProperties": false
        },
        "runtime": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "minLength": 1
            },
            "engine": {
              "type": "string",
              "enum": [
                "deterministic",
                "openclaw",
                "openclaw-gateway",
                "burble-native",
                "hermes"
              ]
            },
            "status": {
              "type": "string",
              "enum": [
                "ready",
                "busy",
                "idle"
              ]
            },
            "policyHash": {
              "type": "string"
            },
            "manifest": {
              "type": "object",
              "properties": {
                "version": {
                  "type": "string",
                  "minLength": 1
                },
                "policyHash": {
                  "type": "string",
                  "minLength": 1
                },
                "skills": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "string",
                        "minLength": 1
                      },
                      "version": {
                        "type": "string",
                        "minLength": 1
                      },
                      "enabled": {
                        "type": "boolean"
                      }
                    },
                    "required": [
                      "id",
                      "version",
                      "enabled"
                    ],
                    "additionalProperties": false
                  }
                },
                "tools": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "name": {
                        "type": "string",
                        "minLength": 1
                      },
                      "alias": {
                        "type": "string",
                        "minLength": 1
                      },
                      "provider": {
                        "type": "string",
                        "minLength": 1
                      },
                      "title": {
                        "type": "string",
                        "minLength": 1
                      },
                      "description": {
                        "type": "string",
                        "minLength": 1
                      },
                      "enabled": {
                        "type": "boolean"
                      },
                      "risk": {
                        "type": "string",
                        "enum": [
                          "read",
                          "low_write",
                          "moderate_write",
                          "high_write"
                        ]
                      },
                      "routeRequired": {
                        "type": "boolean"
                      },
                      "confirmation": {
                        "type": "string",
                        "enum": [
                          "none",
                          "explicit",
                          "strong"
                        ]
                      },
                      "retrySafe": {
                        "type": "boolean"
                      },
                      "input": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "properties": {
                            "name": {
                              "type": "string",
                              "minLength": 1
                            },
                            "type": {
                              "type": "string",
                              "minLength": 1
                            },
                            "required": {
                              "type": "boolean"
                            },
                            "nullable": {
                              "type": "boolean"
                            },
                            "description": {
                              "type": "string"
                            },
                            "values": {
                              "type": "array",
                              "items": {
                                "type": "string"
                              }
                            },
                            "aliases": {
                              "type": "array",
                              "items": {
                                "type": "string",
                                "minLength": 1
                              }
                            }
                          },
                          "required": [
                            "name",
                            "type",
                            "required"
                          ],
                          "additionalProperties": false
                        }
                      }
                    },
                    "required": [
                      "name",
                      "alias",
                      "provider",
                      "title",
                      "description",
                      "enabled",
                      "risk",
                      "routeRequired",
                      "confirmation",
                      "input"
                    ],
                    "additionalProperties": false
                  }
                },
                "memory": {
                  "type": "object",
                  "properties": {
                    "userMemoryEnabled": {
                      "type": "boolean"
                    },
                    "workspaceMemoryEnabled": {
                      "type": "boolean"
                    },
                    "jobMemoryEnabled": {
                      "type": "boolean"
                    }
                  },
                  "required": [
                    "userMemoryEnabled",
                    "workspaceMemoryEnabled",
                    "jobMemoryEnabled"
                  ],
                  "additionalProperties": false
                },
                "streaming": {
                  "default": {
                    "messageDeltasEnabled": true
                  },
                  "type": "object",
                  "properties": {
                    "messageDeltasEnabled": {
                      "type": "boolean"
                    }
                  },
                  "required": [
                    "messageDeltasEnabled"
                  ],
                  "additionalProperties": false
                },
                "memoryContext": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "scope": {
                        "type": "string",
                        "enum": [
                          "user",
                          "workspace",
                          "job"
                        ]
                      },
                      "ownerId": {
                        "type": "string",
                        "minLength": 1
                      },
                      "key": {
                        "type": "string",
                        "minLength": 1
                      },
                      "valuePreview": {
                        "type": "string"
                      },
                      "updatedAt": {
                        "type": "string",
                        "minLength": 1
                      }
                    },
                    "required": [
                      "scope",
                      "ownerId",
                      "key",
                      "valuePreview",
                      "updatedAt"
                    ],
                    "additionalProperties": false
                  }
                }
              },
              "required": [
                "version",
                "policyHash",
                "skills",
                "memory",
                "streaming"
              ],
              "additionalProperties": false
            }
          },
          "required": [
            "id",
            "engine"
          ],
          "additionalProperties": false
        },
        "input": {
          "type": "object",
          "properties": {
            "text": {
              "type": "string",
              "minLength": 1
            },
            "toolGroups": {
              "type": "object",
              "properties": {
                "groups": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "enum": [
                      "attachments",
                      "conversation",
                      "github",
                      "google",
                      "hubspot",
                      "jira",
                      "scheduler",
                      "slack",
                      "web"
                    ]
                  }
                },
                "reasons": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              },
              "required": [
                "groups",
                "reasons"
              ],
              "additionalProperties": false
            },
            "scheduledJob": {
              "type": "object",
              "properties": {
                "jobId": {
                  "type": "string",
                  "minLength": 1
                },
                "capabilityProfile": {
                  "type": "string",
                  "minLength": 1
                },
                "allowedTools": {
                  "minItems": 1,
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "routeId": {
                  "type": "string",
                  "minLength": 1
                },
                "runtimeType": {
                  "type": "string",
                  "enum": [
                    "deterministic",
                    "openclaw",
                    "openclaw-gateway",
                    "burble-native",
                    "hermes"
                  ]
                },
                "stateRefs": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "provider": {
                        "type": "string",
                        "minLength": 1
                      },
                      "kind": {
                        "type": "string",
                        "minLength": 1
                      },
                      "id": {
                        "type": "string"
                      },
                      "name": {
                        "type": "string"
                      },
                      "purpose": {
                        "type": "string"
                      }
                    },
                    "required": [
                      "provider",
                      "kind"
                    ],
                    "additionalProperties": false
                  }
                },
                "visibilityPolicy": {
                  "type": "object",
                  "properties": {
                    "maxOutputVisibility": {
                      "type": "string",
                      "enum": [
                        "public",
                        "user_private",
                        "restricted"
                      ]
                    },
                    "allowPrivateToolDeclassification": {
                      "type": "boolean"
                    }
                  },
                  "additionalProperties": false
                }
              },
              "required": [
                "jobId",
                "capabilityProfile",
                "allowedTools",
                "stateRefs",
                "visibilityPolicy"
              ],
              "additionalProperties": false
            },
            "attachments": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string",
                    "minLength": 1
                  },
                  "kind": {
                    "type": "string",
                    "enum": [
                      "file",
                      "image",
                      "audio",
                      "video"
                    ]
                  },
                  "mimeType": {
                    "type": "string",
                    "minLength": 1
                  },
                  "source": {
                    "type": "string",
                    "enum": [
                      "slack",
                      "burble",
                      "agent"
                    ]
                  },
                  "name": {
                    "type": "string"
                  },
                  "sizeBytes": {
                    "type": "number",
                    "minimum": 0
                  },
                  "externalId": {
                    "type": "string"
                  }
                },
                "required": [
                  "id",
                  "kind",
                  "mimeType",
                  "source"
                ],
                "additionalProperties": {}
              }
            },
            "conversation": {
              "type": "object",
              "properties": {
                "routeId": {
                  "type": "string",
                  "minLength": 1
                },
                "source": {
                  "type": "string",
                  "const": "slack"
                },
                "workspaceId": {
                  "type": "string",
                  "minLength": 1
                },
                "channelId": {
                  "type": "string",
                  "minLength": 1
                },
                "rootId": {
                  "type": "string",
                  "minLength": 1
                },
                "isDirectMessage": {
                  "type": "boolean"
                }
              },
              "required": [
                "source",
                "workspaceId",
                "channelId",
                "rootId",
                "isDirectMessage"
              ],
              "additionalProperties": false
            },
            "context": {
              "type": "object",
              "properties": {
                "currentChannel": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string",
                      "minLength": 1
                    },
                    "isDirectMessage": {
                      "type": "boolean"
                    },
                    "historyAvailable": {
                      "type": "boolean"
                    },
                    "historyError": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "id",
                    "isDirectMessage",
                    "historyAvailable"
                  ],
                  "additionalProperties": false
                },
                "recentMessages": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "author": {
                        "type": "string",
                        "enum": [
                          "user",
                          "assistant"
                        ]
                      },
                      "speaker": {
                        "type": "string"
                      },
                      "text": {
                        "type": "string"
                      }
                    },
                    "required": [
                      "author",
                      "text"
                    ],
                    "additionalProperties": false
                  }
                }
              },
              "required": [
                "recentMessages"
              ],
              "additionalProperties": false
            },
            "connections": {
              "type": "object",
              "properties": {
                "github": {
                  "type": "object",
                  "properties": {
                    "connected": {
                      "type": "boolean"
                    },
                    "email": {
                      "type": "string"
                    },
                    "providerLogin": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "connected"
                  ],
                  "additionalProperties": {}
                },
                "google": {
                  "type": "object",
                  "properties": {
                    "connected": {
                      "type": "boolean"
                    },
                    "email": {
                      "type": "string"
                    },
                    "providerLogin": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "connected"
                  ],
                  "additionalProperties": {}
                },
                "hubspot": {
                  "type": "object",
                  "properties": {
                    "connected": {
                      "type": "boolean"
                    },
                    "email": {
                      "type": "string"
                    },
                    "providerLogin": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "connected"
                  ],
                  "additionalProperties": {}
                },
                "jira": {
                  "type": "object",
                  "properties": {
                    "connected": {
                      "type": "boolean"
                    },
                    "email": {
                      "type": "string"
                    },
                    "providerLogin": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "connected"
                  ],
                  "additionalProperties": {}
                },
                "slack": {
                  "type": "object",
                  "properties": {
                    "connected": {
                      "type": "boolean"
                    },
                    "email": {
                      "type": "string"
                    },
                    "providerLogin": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "connected"
                  ],
                  "additionalProperties": {}
                }
              },
              "additionalProperties": false
            }
          },
          "required": [
            "text",
            "connections"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "principal",
        "runtime",
        "input"
      ],
      "additionalProperties": false
    },
    "RuntimeRunEvent": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "status"
            },
            "text": {
              "type": "string"
            }
          },
          "required": [
            "type",
            "text"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "message_delta"
            },
            "text": {
              "type": "string"
            }
          },
          "required": [
            "type",
            "text"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "message_replace"
            },
            "text": {
              "type": "string"
            }
          },
          "required": [
            "type",
            "text"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "tool_call"
            },
            "toolName": {
              "type": "string",
              "minLength": 1
            },
            "callId": {
              "type": "string",
              "minLength": 1
            },
            "input": {}
          },
          "required": [
            "type",
            "toolName",
            "callId"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "tool_result"
            },
            "toolName": {
              "type": "string",
              "minLength": 1
            },
            "callId": {
              "type": "string",
              "minLength": 1
            },
            "classification": {
              "type": "string",
              "enum": [
                "public",
                "user_private",
                "restricted"
              ]
            },
            "status": {
              "type": "string",
              "enum": [
                "ok",
                "error"
              ]
            },
            "content": {}
          },
          "required": [
            "type",
            "toolName",
            "callId",
            "classification"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "usage"
            },
            "usage": {
              "$ref": "RuntimeUsage"
            }
          },
          "required": [
            "type",
            "usage"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "heartbeat"
            },
            "status": {
              "type": "string"
            }
          },
          "required": [
            "type"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "final"
            },
            "response": {
              "type": "object",
              "properties": {
                "classification": {
                  "type": "string",
                  "enum": [
                    "public",
                    "user_private",
                    "restricted"
                  ]
                },
                "text": {
                  "type": "string"
                },
                "blocks": {
                  "type": "array",
                  "items": {}
                },
                "attachments": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "string",
                        "minLength": 1
                      },
                      "kind": {
                        "type": "string",
                        "enum": [
                          "file",
                          "image",
                          "audio",
                          "video"
                        ]
                      },
                      "mimeType": {
                        "type": "string",
                        "minLength": 1
                      },
                      "source": {
                        "type": "string",
                        "enum": [
                          "slack",
                          "burble",
                          "agent"
                        ]
                      },
                      "name": {
                        "type": "string"
                      },
                      "sizeBytes": {
                        "type": "number",
                        "minimum": 0
                      },
                      "externalId": {
                        "type": "string"
                      }
                    },
                    "required": [
                      "id",
                      "kind",
                      "mimeType",
                      "source"
                    ],
                    "additionalProperties": {}
                  }
                },
                "usage": {
                  "allOf": [
                    {
                      "$ref": "RuntimeUsage"
                    }
                  ]
                },
                "telemetry": {
                  "type": "object",
                  "propertyNames": {
                    "type": "string"
                  },
                  "additionalProperties": {}
                }
              },
              "required": [
                "classification",
                "text"
              ],
              "additionalProperties": false
            }
          },
          "required": [
            "type",
            "response"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "error"
            },
            "message": {
              "type": "string",
              "minLength": 1
            },
            "code": {
              "type": "string"
            }
          },
          "required": [
            "type",
            "message"
          ],
          "additionalProperties": false
        }
      ]
    },
    "RuntimeCapabilityManifest": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "type": "object",
      "properties": {
        "runtimeType": {
          "type": "string",
          "enum": [
            "deterministic",
            "openclaw",
            "openclaw-gateway",
            "burble-native",
            "hermes"
          ]
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "transports": {
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "http",
              "sse",
              "ndjson",
              "websocket"
            ]
          }
        },
        "streaming": {
          "type": "boolean"
        },
        "cancellation": {
          "type": "boolean"
        },
        "nativeScheduler": {
          "type": "boolean"
        },
        "scheduledProviderCalls": {
          "type": "boolean"
        },
        "toolCalls": {
          "type": "boolean"
        },
        "toolBridgeModes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "tool_gateway",
              "mcp"
            ]
          }
        },
        "usageReporting": {
          "type": "string",
          "enum": [
            "exact",
            "estimated",
            "none"
          ]
        },
        "multimodalInput": {
          "type": "boolean"
        },
        "multimodalOutput": {
          "type": "boolean"
        },
        "memory": {
          "type": "boolean"
        },
        "durableWorkflowState": {
          "type": "boolean"
        },
        "attachments": {
          "type": "boolean"
        },
        "conversationSend": {
          "type": "boolean"
        },
        "jobScopedAuth": {
          "type": "boolean"
        }
      },
      "required": [
        "runtimeType",
        "version",
        "transports",
        "streaming",
        "cancellation",
        "nativeScheduler",
        "scheduledProviderCalls",
        "toolCalls",
        "toolBridgeModes",
        "usageReporting",
        "multimodalInput",
        "multimodalOutput",
        "memory",
        "durableWorkflowState",
        "attachments",
        "conversationSend",
        "jobScopedAuth"
      ],
      "additionalProperties": {}
    },
    "RuntimeUsage": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "type": "object",
      "properties": {
        "inputTokens": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "outputTokens": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "totalTokens": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "cachedInputTokens": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "reasoningTokens": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "usageSource": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
